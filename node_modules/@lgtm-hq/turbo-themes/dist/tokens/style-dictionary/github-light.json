{
  "spacing": {
    "xs": {
      "$value": "0.25rem",
      "$type": "dimension"
    },
    "sm": {
      "$value": "0.5rem",
      "$type": "dimension"
    },
    "md": {
      "$value": "1rem",
      "$type": "dimension"
    },
    "lg": {
      "$value": "1.5rem",
      "$type": "dimension"
    },
    "xl": {
      "$value": "2rem",
      "$type": "dimension"
    }
  },
  "elevation": {
    "none": {
      "$value": "none",
      "$type": "shadow"
    },
    "sm": {
      "$value": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "$type": "shadow"
    },
    "md": {
      "$value": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
      "$type": "shadow"
    },
    "lg": {
      "$value": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
      "$type": "shadow"
    },
    "xl": {
      "$value": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)",
      "$type": "shadow"
    }
  },
  "animation": {
    "durationFast": {
      "$value": "150ms",
      "$type": "duration"
    },
    "durationNormal": {
      "$value": "300ms",
      "$type": "duration"
    },
    "durationSlow": {
      "$value": "500ms",
      "$type": "duration"
    },
    "easingDefault": {
      "$value": "cubic-bezier(0.4, 0, 0.2, 1)",
      "$type": "cubicBezier"
    },
    "easingEmphasized": {
      "$value": "cubic-bezier(0.05, 0.7, 0.1, 1)",
      "$type": "cubicBezier"
    }
  },
  "opacity": {
    "disabled": {
      "$value": 0.5,
      "$type": "number"
    },
    "hover": {
      "$value": 0.8,
      "$type": "number"
    },
    "pressed": {
      "$value": 0.6,
      "$type": "number"
    }
  },
  "background": {
    "base": {
      "$value": "#ffffff",
      "$type": "color"
    },
    "surface": {
      "$value": "#f6f8fa",
      "$type": "color"
    },
    "overlay": {
      "$value": "#f6f8fa",
      "$type": "color"
    }
  },
  "text": {
    "primary": {
      "$value": "#1f2328",
      "$type": "color"
    },
    "secondary": {
      "$value": "#59636e",
      "$type": "color"
    },
    "inverse": {
      "$value": "#ffffff",
      "$type": "color"
    }
  },
  "brand": {
    "primary": {
      "$value": "#0969da",
      "$type": "color"
    }
  },
  "state": {
    "info": {
      "$value": "#0969da",
      "$type": "color"
    },
    "success": {
      "$value": "#1a7f37",
      "$type": "color"
    },
    "warning": {
      "$value": "#9a6700",
      "$type": "color"
    },
    "danger": {
      "$value": "#d1242f",
      "$type": "color"
    }
  },
  "border": {
    "default": {
      "$value": "#d1d9e0",
      "$type": "color"
    }
  },
  "accent": {
    "link": {
      "$value": "#0969da",
      "$type": "color"
    }
  },
  "typography": {
    "fonts": {
      "sans": {
        "$value": "\"Mona Sans\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", \"Noto Sans\", Helvetica, Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\"",
        "$type": "fontFamily"
      },
      "mono": {
        "$value": "\"Hubot Sans\", ui-monospace, SFMono-Regular, SF Mono, Menlo, Consolas, \"Liberation Mono\", monospace",
        "$type": "fontFamily"
      }
    },
    "webFonts": [
      "https://github.githubassets.com/assets/mona-sans-webfont.woff2",
      "https://github.githubassets.com/assets/hubot-sans-webfont.woff2"
    ]
  },
  "content": {
    "heading": {
      "h1": {
        "$value": "#1a7f37",
        "$type": "color"
      },
      "h2": {
        "$value": "#0969da",
        "$type": "color"
      },
      "h3": {
        "$value": "#0969da",
        "$type": "color"
      },
      "h4": {
        "$value": "#9a6700",
        "$type": "color"
      },
      "h5": {
        "$value": "#1a7f37",
        "$type": "color"
      },
      "h6": {
        "$value": "#d1242f",
        "$type": "color"
      }
    },
    "body": {
      "primary": {
        "$value": "#1f2328",
        "$type": "color"
      },
      "secondary": {
        "$value": "#59636e",
        "$type": "color"
      }
    },
    "link": {
      "default": {
        "$value": "#0969da",
        "$type": "color"
      }
    },
    "selection": {
      "fg": {
        "$value": "#1f2328",
        "$type": "color"
      },
      "bg": {
        "$value": "#b6e3ff",
        "$type": "color"
      }
    },
    "blockquote": {
      "border": {
        "$value": "#d1d9e0",
        "$type": "color"
      },
      "fg": {
        "$value": "#59636e",
        "$type": "color"
      },
      "bg": {
        "$value": "#f6f8fa",
        "$type": "color"
      }
    },
    "codeInline": {
      "fg": {
        "$value": "#1f2328",
        "$type": "color"
      },
      "bg": {
        "$value": "#f6f8fa",
        "$type": "color"
      }
    },
    "codeBlock": {
      "fg": {
        "$value": "#1f2328",
        "$type": "color"
      },
      "bg": {
        "$value": "#f6f8fa",
        "$type": "color"
      }
    },
    "table": {
      "border": {
        "$value": "#d1d9e0",
        "$type": "color"
      },
      "stripe": {
        "$value": "#f6f8fa",
        "$type": "color"
      },
      "theadBg": {
        "$value": "#f6f8fa",
        "$type": "color"
      }
    }
  }
}