{
  "spacing": {
    "xs": {
      "$value": "0.25rem",
      "$type": "dimension"
    },
    "sm": {
      "$value": "0.5rem",
      "$type": "dimension"
    },
    "md": {
      "$value": "1rem",
      "$type": "dimension"
    },
    "lg": {
      "$value": "1.5rem",
      "$type": "dimension"
    },
    "xl": {
      "$value": "2rem",
      "$type": "dimension"
    }
  },
  "elevation": {
    "none": {
      "$value": "none",
      "$type": "shadow"
    },
    "sm": {
      "$value": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "$type": "shadow"
    },
    "md": {
      "$value": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
      "$type": "shadow"
    },
    "lg": {
      "$value": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
      "$type": "shadow"
    },
    "xl": {
      "$value": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)",
      "$type": "shadow"
    }
  },
  "animation": {
    "durationFast": {
      "$value": "150ms",
      "$type": "duration"
    },
    "durationNormal": {
      "$value": "300ms",
      "$type": "duration"
    },
    "durationSlow": {
      "$value": "500ms",
      "$type": "duration"
    },
    "easingDefault": {
      "$value": "cubic-bezier(0.4, 0, 0.2, 1)",
      "$type": "cubicBezier"
    },
    "easingEmphasized": {
      "$value": "cubic-bezier(0.05, 0.7, 0.1, 1)",
      "$type": "cubicBezier"
    }
  },
  "opacity": {
    "disabled": {
      "$value": 0.5,
      "$type": "number"
    },
    "hover": {
      "$value": 0.8,
      "$type": "number"
    },
    "pressed": {
      "$value": 0.6,
      "$type": "number"
    }
  },
  "background": {
    "base": {
      "$value": "#0d0d0d",
      "$type": "color"
    },
    "surface": {
      "$value": "#080808",
      "$type": "color"
    },
    "overlay": {
      "$value": "#111111",
      "$type": "color"
    }
  },
  "text": {
    "primary": {
      "$value": "#c8ffc8",
      "$type": "color"
    },
    "secondary": {
      "$value": "#8fbc8f",
      "$type": "color"
    },
    "inverse": {
      "$value": "#0d0d0d",
      "$type": "color"
    }
  },
  "brand": {
    "primary": {
      "$value": "#39ff14",
      "$type": "color"
    }
  },
  "state": {
    "info": {
      "$value": "#7dd3fc",
      "$type": "color"
    },
    "success": {
      "$value": "#39ff14",
      "$type": "color"
    },
    "warning": {
      "$value": "#ffb000",
      "$type": "color"
    },
    "danger": {
      "$value": "#ff4444",
      "$type": "color"
    }
  },
  "border": {
    "default": {
      "$value": "#1f3d1f",
      "$type": "color"
    }
  },
  "accent": {
    "link": {
      "$value": "#7dd3fc",
      "$type": "color"
    }
  },
  "typography": {
    "fonts": {
      "sans": {
        "$value": "\"IBM Plex Mono\", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
        "$type": "fontFamily"
      },
      "mono": {
        "$value": "\"IBM Plex Mono\", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
        "$type": "fontFamily"
      }
    },
    "webFonts": [
      "https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&display=swap"
    ]
  },
  "content": {
    "heading": {
      "h1": {
        "$value": "#39ff14",
        "$type": "color"
      },
      "h2": {
        "$value": "#7dd3fc",
        "$type": "color"
      },
      "h3": {
        "$value": "#ffb000",
        "$type": "color"
      },
      "h4": {
        "$value": "#39ff14",
        "$type": "color"
      },
      "h5": {
        "$value": "#8fbc8f",
        "$type": "color"
      },
      "h6": {
        "$value": "#c8ffc8",
        "$type": "color"
      }
    },
    "body": {
      "primary": {
        "$value": "#c8ffc8",
        "$type": "color"
      },
      "secondary": {
        "$value": "#8fbc8f",
        "$type": "color"
      }
    },
    "link": {
      "default": {
        "$value": "#7dd3fc",
        "$type": "color"
      }
    },
    "selection": {
      "fg": {
        "$value": "#0d0d0d",
        "$type": "color"
      },
      "bg": {
        "$value": "#39ff14",
        "$type": "color"
      }
    },
    "blockquote": {
      "border": {
        "$value": "#39ff14",
        "$type": "color"
      },
      "fg": {
        "$value": "#8fbc8f",
        "$type": "color"
      },
      "bg": {
        "$value": "#111111",
        "$type": "color"
      }
    },
    "codeInline": {
      "fg": {
        "$value": "#ffb000",
        "$type": "color"
      },
      "bg": {
        "$value": "#111111",
        "$type": "color"
      }
    },
    "codeBlock": {
      "fg": {
        "$value": "#c8ffc8",
        "$type": "color"
      },
      "bg": {
        "$value": "#080808",
        "$type": "color"
      }
    },
    "table": {
      "border": {
        "$value": "#1f3d1f",
        "$type": "color"
      },
      "stripe": {
        "$value": "#111111",
        "$type": "color"
      },
      "theadBg": {
        "$value": "#080808",
        "$type": "color"
      },
      "headerFg": {
        "$value": "#c8ffc8",
        "$type": "color"
      }
    }
  }
}