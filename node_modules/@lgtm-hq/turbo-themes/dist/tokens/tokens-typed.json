{
  "spacing-xs": {
    "value": "0.25rem",
    "$type": "dimension"
  },
  "spacing-sm": {
    "value": "0.5rem",
    "$type": "dimension"
  },
  "spacing-md": {
    "value": "1rem",
    "$type": "dimension"
  },
  "spacing-lg": {
    "value": "1.5rem",
    "$type": "dimension"
  },
  "spacing-xl": {
    "value": "2rem",
    "$type": "dimension"
  },
  "elevation-none": {
    "value": "none",
    "$type": "shadow"
  },
  "elevation-sm": {
    "value": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "$type": "shadow"
  },
  "elevation-md": {
    "value": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
    "$type": "shadow"
  },
  "elevation-lg": {
    "value": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
    "$type": "shadow"
  },
  "elevation-xl": {
    "value": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)",
    "$type": "shadow"
  },
  "animation-duration-fast": {
    "value": "150ms",
